{
  "plugin-menu": {
    "prefix": "plugin-menu",
    "scope": "json",
    "body": [
      "{",
      "  \"name\": \"${1:菜单名}\",",
      "  \"router\": \"/${2:key}\",",
      "  \"appKey\": \"${2:key}\",",
      "  \"icon\": \"${3:icon-app}\",",
      "  \"orderNum\": ${4:99},",
      "  \"isShow\": true",
      "}"
    ],
    "description": "module.json.menus 单项（appKey 必须等于插件 key；wujie → /vome/apps/{key}/）"
  },
  "plugin-module": {
    "prefix": "plugin-module",
    "scope": "json",
    "body": [
      "{",
      "  \"name\": \"${1:插件名}\",",
      "  \"key\": \"${2:my-front}\",",
      "  \"version\": \"${3:1.0.0}\",",
      "  \"description\": \"${4:描述}\",",
      "  \"author\": \"${5:vome}\",",
      "  \"logo\": \"assets/logo.png\",",
      "  \"readme\": \"README.md\",",
      "  \"menus\": [",
      "    {",
      "      \"name\": \"${1:插件名}\",",
      "      \"router\": \"/${2:my-front}\",",
      "      \"appKey\": \"${2:my-front}\",",
      "      \"icon\": \"icon-app\",",
      "      \"orderNum\": 99,",
      "      \"isShow\": true",
      "    }",
      "  ]",
      "}",
      ""
    ],
    "description": "纯前端 module.json 骨架（勿声明 hook/routes）"
  },
  "plugin-vue-app": {
    "prefix": "plugin-vue",
    "scope": "vue",
    "body": [
      "<template>",
      "  <main class=\"page\">",
      "    <h1>${1:插件名}</h1>",
      "    <p>$0</p>",
      "  </main>",
      "</template>",
      "",
      "<script setup lang=\"ts\">",
      "defineOptions({ name: '${2:App}' })",
      "</script>",
      "",
      "<style scoped>",
      ".page {",
      "  min-height: 100vh;",
      "  margin: 0;",
      "  display: grid;",
      "  place-items: center;",
      "  text-align: center;",
      "  font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;",
      "  background: #f5f7fb;",
      "  color: #1a1d26;",
      "}",
      "",
      "h1 {",
      "  margin: 0 0 0.5rem;",
      "  font-size: 1.5rem;",
      "  color: #4e5dff;",
      "}",
      "",
      "p {",
      "  margin: 0;",
      "  opacity: 0.75;",
      "}",
      "</style>",
      ""
    ],
    "description": "插件 Vue3 SFC（源码 src/，构建到 web/）"
  },
  "plugin-vue-main": {
    "prefix": "plugin-main",
    "scope": "typescript",
    "body": [
      "import { createApp } from 'vue'",
      "import App from './App.vue'",
      "",
      "createApp(App).mount('#app')",
      ""
    ],
    "description": "插件 Vue3 入口 main.ts"
  },
  "plugin-fetch-admin": {
    "prefix": "plugin-fetch",
    "scope": "typescript,javascript",
    "body": [
      "import { hostRequest } from '@/lib/host-api'",
      "",
      "/** 同域 + Bearer（vome_admin_access）+ /dev|/prod 前缀 */",
      "const data = await hostRequest('${1|GET,POST|}', '${2:/admin/base/auth/me}'${3:, body})",
      ""
    ],
    "description": "微应用 hostRequest 调宿主（见 src/lib/host-api.ts）"
  }
}
